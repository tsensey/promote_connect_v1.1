{
  "appId": "com.promoteconnect.app",
  "appName": "PROMOTE-CONNECT",
  "webDir": "out",
  "bundledWebRuntime": false,
  "appendUserAgent": "CapacitorApp",
  "plugins": {
    "StatusBar": {
      "style": "DARK"
    },
    "SplashScreen": {
      "launchShowDuration": 3000,
      "backgroundColor": "#581F47",
      "layoutName": "launch_screen",
      "useDialog": true,
      "showSpinner": true,
      "androidSpinnerStyle": "large"
    }
  }
}
