# PROMOTE-CONNECT — Variables d'Environnement
# Copier ce fichier en .env.local et remplir les valeurs

# ─── Supabase ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_ANNUAL=price_...

# ─── Resend (Email / Newsletter) ─────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=newsletter@promote-connect.com
RESEND_FROM_NAME=PROMOTE-CONNECT

# ─── Firebase (Push Notifications) ───────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FCM_SERVER_KEY=

# ─── Application ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://promote-connect.com
NODE_ENV=development
