# PROMOTE-CONNECT — Variables d'Environnement
# Copier ce fichier en .env.local et remplir les valeurs

# ─── Supabase ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_key
STRIPE_PRICE_ID_ANNUAL=price_your_price_id

# ─── Resend (Email / Newsletter) ─────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=newsletter@promote-connect.com
RESEND_FROM_NAME=PROMOTE-CONNECT

# ─── Firebase (Push Notifications) ───────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FCM_SERVER_KEY=

# ─── PWA / Store ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Android TWA : package name (doit correspondre à assetlinks.json)
NEXT_PUBLIC_ANDROID_PACKAGE_NAME=com.promoteconnect.app
# iOS : Apple Team ID (pour apple-app-site-association)
NEXT_PUBLIC_IOS_TEAM_ID=CHANGE_ME
# iOS : App Store ID (pour Smart App Banner)
NEXT_PUBLIC_IOS_APP_STORE_ID=

# ─── Sentry (Error Tracking) ─────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# ─── Plausible (Analytics) ───────────────────────────
NEXT_PUBLIC_PLAUSIBLE_URL=https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=promote-connect.com
